{
  "name": "@sudo-ai-receptionist/receptionist-api",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/apps/receptionist-api/src/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/apps/receptionist-api/src/server.js",
    "dev": "tsx src/server.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build:api": "npm run build -ws --if-present"
  },
  "dependencies": {
    "@sudo-ai-receptionist/agent-core": "file:../../packages/agent-core",
    "@sudo-ai-receptionist/salonflow": "file:../../integrations/salonflow",
    "@sudo-ai-receptionist/mock-business": "file:../../integrations/mock-business",
    "@sudo-ai-receptionist/realtime-runtime": "file:../../packages/realtime-runtime",
    "@sudo-ai-receptionist/shared": "file:../../packages/shared"
  }
}
